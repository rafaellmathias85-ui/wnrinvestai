# ── Como rodar localmente ─────────────────────────────────────
# 1. Copie este arquivo:  cp api/.env.example api/.env
# 2. Instale dependências: npm run install   (ou: cd api && npm install)
# 3. Inicie o servidor:   npm run dev        (ou: node api/server.js)
# 4. Abra no browser:     http://localhost:3001/investai
#
# As variáveis abaixo são obrigatórias para as funcionalidades funcionarem.
# Em produção (VPS) elas são injetadas pelo GitHub Actions — não commite o .env real.
# ------------------------------------------------------------------------------

# ── Anthropic (Claude AI) ─────────────────────────────────────
# Obtenha em: https://console.anthropic.com → API Keys → Create Key
# Com esta variável o endpoint /api/ai funciona como proxy seguro (chave não exposta no browser).
ANTHROPIC_API_KEY=sk-ant-apiXX-xxxxxxxxxxxxxxxxxxxxxxxx

# ── Mercado Pago ─────────────────────────────────────────────
# Obtenha em: https://www.mercadopago.com.br/developers/panel
# Necessário apenas para a funcionalidade de pagamento/checkout.
MP_ACCESS_TOKEN=APP_USR-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Servidor ──────────────────────────────────────────────────
PORT=3001
